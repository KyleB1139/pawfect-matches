diff --git a/supabase/migrations/20260720000001_private_photo_buckets.sql b/supabase/migrations/20260720000001_private_photo_buckets.sql
new file mode 100644
index 0000000..5c7ebb9
--- /dev/null
+++ b/supabase/migrations/20260720000001_private_photo_buckets.sql
@@ -0,0 +1,5 @@
+-- Photos were served from public buckets, bypassing the authenticated-only
+-- SELECT policies. Buckets are now private; the app signs URLs at display time.
+UPDATE storage.buckets
+SET public = false
+WHERE id IN ('avatars', 'dog-photos', 'profile-photos');
